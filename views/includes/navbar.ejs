<nav class="navbar navbar-expand-md bg-white border-bottom sticky-top">
  <div class="container-fluid px-4">

    <!-- Brand -->
    <a class="navbar-brand" href="/">
      <i class="fa-solid fa-compass" style="color:#fe424d; font-size:1.5rem;"></i>
    </a>

    <!-- Toggler -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
      data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">

      <!-- Left: always visible -->
      <ul class="navbar-nav me-auto">
        <li class="nav-item">
          <a class="nav-link" href="/">Home</a>
        </li>
        <li class="nav-item">
          <a class="nav-link" href="/listings">All Listings</a>
        </li>
        <!-- Add new Listing only when logged in -->
        <% if(currUser) { %>
