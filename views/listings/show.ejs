<% layout("/layouts/boilerplate") %>

<div class="row mt-3 mb-5">
  <div class="col-md-8 offset-md-2 col-lg-6 offset-lg-3">
    <h3 class="mb-3 fw-bold"><%= listing.title %></h3>

    <div class="card show-card">
      <img src="<%= listing.image.url %>" class="card-img-top show-image" alt="listing_image"
        onerror="this.src='https://placehold.co/800x400?text=No+Image'">
      <div class="card-body p-4">
        <p class="text-muted mt-2"><%= listing.description %></p>
        <hr>
        <p class="mb-1">
          <strong>&#8377; <%= listing.price.toLocaleString("en-IN") %></strong> / night
        </p>
        <p class="mb-1 text-secondary">
          <i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %>
        </p>
        <% if(listing.owner) { %>
        <p class="mb-0 text-muted" style="font-size:0.85rem;">
          <i class="fa-solid fa-user me-1"></i>Hosted by <strong><%= listing.owner.username %></strong>
        </p>
        <% } %>
      </div>

      <!-- Edit/Delete only for owner -->
      <% if(currUser && listing.owner && listing.owner._id.equals(currUser._id)) { %>
      <div class="btns border-top p-3">
        <a href="/listings/<%= listing._id %>/edit" class="btn edit-btn">Edit</a>
        <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE" class="d-inline">
          <button class="btn btn-outline-danger">Delete</button>
        </form>
      </div>
      <% } %>
    </div>

    <!-- Leave a Review — only for logged-in users -->
    <% if(currUser) { %>
    <div class="mt-4">
      <h4 class="mb-3">Leave a Review</h4>
      <form action="/listings/<%= listing._id %>/reviews" method="POST"
        novalidate class="needs-validation p-4 rounded-3 border bg-white shadow-sm">

        <div class="mb-3">
          <label class="form-label fw-semibold">Your Rating</label>
          <div class="star-rating">
            <input type="radio" id="star5" name="review[rating]" value="5">
            <label for="star5"><i class="fa-solid fa-star"></i></label>
            <input type="radio" id="star4" name="review[rating]" value="4">
            <label for="star4"><i class="fa-solid fa-star"></i></label>
            <input type="radio" id="star3" name="review[rating]" value="3" checked>
            <label for="star3"><i class="fa-solid fa-star"></i></label>
            <input type="radio" id="star2" name="review[rating]" value="2">
            <label for="star2"><i class="fa-solid fa-star"></i></label>
            <input type="radio" id="star1" name="review[rating]" value="1">
            <label for="star1"><i class="fa-solid fa-star"></i></label>
          </div>
        </div>

        <div class="mb-3">
          <label for="comment" class="form-label fw-semibold">Your Comment</label>
          <textarea name="review[comment]" id="comment" rows="3"
            class="form-control" placeholder="Share your experience..." required></textarea>
          <div class="invalid-feedback">Please add a comment.</div>
        </div>

        <button class="btn add-btn">Submit Review</button>
      </form>
    </div>
    <% } else { %>
    <div class="mt-4 p-3 rounded-3 border text-center bg-white">
      <p class="mb-1 text-muted">Want to leave a review?</p>
      <a href="/login" class="btn add-btn btn-sm">Log in to Review</a>
    </div>
    <% } %>

    <!-- All Reviews -->
    <% if(listing.reviews.length > 0) { %>
    <div class="mt-4">
      <h4 class="mb-3">All Reviews</h4>
      <div class="row g-3">
        <% for(let review of listing.reviews) { %>
        <div class="col-12">
          <div class="review-card p-3 rounded-3 border bg-white shadow-sm d-flex justify-content-between align-items-start">
            <div>
              <div class="mb-1">
                <% for(let i = 1; i <= 5; i++) { %>
                  <i class="fa-solid fa-star <%= i <= review.rating ? 'text-warning' : 'text-secondary opacity-25' %>"
                    style="font-size:0.9rem;"></i>
                <% } %>
                <span class="ms-1 text-muted" style="font-size:0.85rem;"><%= review.rating %>/5</span>
              </div>
              <p class="mb-0 text-dark"><%= review.comment %></p>
              <% if(review.author) { %>
              <small class="text-muted">
                <i class="fa-solid fa-user me-1"></i><%= review.author.username %>
              </small>
              <% } %>
            </div>

            <!-- Delete review — only for review author -->
            <% if(currUser && review.author && review.author._id.equals(currUser._id)) { %>
            <form method="POST"
              action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
              <button class="btn btn-sm btn-outline-danger ms-3">
                <i class="fa-solid fa-trash"></i>
              </button>
            </form>
            <% } %>
          </div>
        </div>
        <% } %>
      </div>
    </div>
    <% } %>

  </div>
</div>