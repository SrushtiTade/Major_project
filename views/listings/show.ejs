<% layout("/layouts/boilerplate") %>
<div class="row mt-3 mb-5">
  <div class="col-md-8 offset-md-2 col-lg-6 offset-lg-3">
    <h3 class="mb-3 fw-bold"><%= listing.title %></h3>
    <div class="card show-card">
      <img src="<%= listing.image.url %>" class="card-img-top show-image" alt="listing_image">
      <div class="card-body p-4">
        
        <p class="text-muted mt-2"><%= listing.description %></p>
        <hr>
        <p class="mb-1"><strong>&#8377; <%= listing.price.toLocaleString("en-IN") %></strong> / night</p>
        <p class="mb-1 text-secondary"><i class="fa-solid fa-location-dot me-1"></i><%= listing.location %>, <%= listing.country %></p>
      </div>
      <div class="btns border-top">
        <a href="/listings/<%= listing._id %>/edit" class="btn edit-btn">Edit</a>
        <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
          <button class="btn btn-outline-danger">Delete</button>
        </form action="/listings/<%= listing.id %>/reviews"
         method="POST" novalidate class="needs-validation">
      </div>
      <div class="col-md-8 offset-md-2>
        <hr>
        <h4>Leave a Review</h4>
        <form >
          <div class="mb-3 mt-3">
            <label for="rating"  class="form-lable">Rating</label>
            <input type="range" min="1" max="5" id="rating" 
            name="review[rating]" class="form-range">
          </div>
          <div class="mb-3 mt-3">
            <label for="comment"  class="form-lable">Comment</label>
            <textarea name="review[comment]" id="comment" 
            cols="30" rows="5"  class="form-control" required></textarea>
             <div class="invalid-feedback">Please add comment for review</div>
          </div>
          <button >Submit</button>
        </form>
        <hr>
        <h4>All Review</h4>
      
         <% for(review of listing.reviews){ %>
          <div class="card col-5 ms-3 mb-3">
                  <div class="card-body">
                           <h5 class="card-title">jane doe</h5>
                           <p class="card-text"><%= review.comment%></p>
                             <p class="card-text"><%= review.rating%></p>
                             <form class="mb-3" mrthod="POST"
                              action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                              <button class="btn btn-sm bt-dark">Delete</button>
                             </form>
                  </div>
          </div>
        <%} %>
      </div>
    </div>
  </div>
</div>