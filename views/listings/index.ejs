<% layout("/layouts/boilerplate") %>
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4 mt-2">
  <% for(let listing of allListings) { %>
    <div class="col">
      <a href="/listings/<%= listing._id %>" class="listing-link text-decoration-none">
        <div class="card h-100 listing-card">
          <img src="<%= listing.image.url %>" 
               class="card-img-top" 
               alt="listing-image"
               style="height: 220px; object-fit:cover; border-radius: 12px 12px 0 0;">
          <div class="card-body">
            <p class="card-title fw-bold mb-1 text-dark"><%= listing.title %></p>
            <p class="card-text text-muted" style="font-size:0.9rem;">
              &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
            </p>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>


